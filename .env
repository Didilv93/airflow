# Copy this file to .env and fill in all values before running docker compose.
# Generate Fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate random strings:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
POSTGRES_USER=airflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=airflow

# ---------------------------------------------------------------------------
# Airflow core
# ---------------------------------------------------------------------------
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ---------------------------------------------------------------------------
# Webserver
# ---------------------------------------------------------------------------
AIRFLOW__WEBSERVER__SECRET_KEY=changeme
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=false

# ---------------------------------------------------------------------------
# Admin user (used by airflow-init container on first run)
# ---------------------------------------------------------------------------
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=changeme